PORT=5000
MONGO_URI=mongodb://localhost:27017/complaint_portal
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
NODE_ENV=development

# CORS - frontend URL(s) allowed to call the API (comma-separated for multiple)
# Required in production when frontend is on a different domain
# CLIENT_URL=https://jharkhand-wifi-complain.onrender.com

# Email (for OTP on ticket resolution) - optional; if not set, OTP is logged to console
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=JH Health WiFi <noreply@jhhealthwifi.gov.in>

# Cloudinary (for complaint image attachments)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
